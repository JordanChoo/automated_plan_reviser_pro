# Direct API Backend
# -----------------------------------------------------------------------------

API_ERROR_MESSAGE=""
API_RESPONSE_ID=""
API_RESPONSE_STATUS=""

api_sessions_dir() {
    printf '%s\n' "$CONFIG_DIR/api_sessions"
}

api_session_path() {
    local slug="$1"
    printf '%s/%s.json\n' "$(api_sessions_dir)" "$slug"
}

api_response_log_path() {
    local slug="$1"
    printf '%s/logs/api_%s.json\n' "$CONFIG_DIR" "$slug"
}

api_normalize_model() {
    local configured="${1:-}"
    configured=$(yaml_unquote "$configured")

    case "$configured" in
        ""|"5.2 Thinking"|"GPT Pro 5.2"|"GPT Pro 5.2 Extended Reasoning")
            printf '%s\n' "$APR_DEFAULT_MODEL"
            ;;
        "5.2 Pro"|"GPT-5.2 Pro"|"gpt-5.2 pro")
            printf '%s\n' "gpt-5.2-pro"
            ;;
        "5.2"|"GPT-5.2")
            printf '%s\n' "gpt-5.2"
            ;;
        "5.5"|"GPT-5.5")
            printf '%s\n' "gpt-5.5"
            ;;
        "5.5 Pro"|"GPT-5.5 Pro"|"gpt-5.5 pro")
            printf '%s\n' "gpt-5.5-pro"
            ;;
        *)
            printf '%s\n' "$configured"
            ;;
    esac
}

api_reasoning_effort() {
    local thinking_time="${1:-}"

    if [[ -n "${APR_REASONING_EFFORT:-}" ]]; then
        printf '%s\n' "$APR_REASONING_EFFORT"
        return 0
    fi

    case "$thinking_time" in
        light|low) printf '%s\n' "low" ;;
        medium|normal) printf '%s\n' "medium" ;;
        heavy|high) printf '%s\n' "high" ;;
        xheavy|xhigh|max) printf '%s\n' "xhigh" ;;
        none) printf '%s\n' "none" ;;
        "") printf '%s\n' "high" ;;
        *) printf '%s\n' "high" ;;
    esac
}

check_api() {
    if [[ -z "${OPENAI_API_KEY:-}" ]]; then
        API_ERROR_MESSAGE="OPENAI_API_KEY is not set"
        return 1
    fi
    if ! command -v curl &>/dev/null; then
        API_ERROR_MESSAGE="curl is required for direct API execution"
        return 1
    fi
    if ! command -v jq &>/dev/null; then
        API_ERROR_MESSAGE="jq is required for direct API execution"
        return 1
    fi
    API_ERROR_MESSAGE=""
    return 0
}

api_error_from_file() {
    local response_file="$1"
    jq -r '.error.message // .message // empty' "$response_file" 2>/dev/null || true
}

api_call() {
    local method="$1"
    local endpoint="$2"
    local body="${3:-}"
    local response_file="$4"
    local url="${OPENAI_BASE_URL%/}$endpoint"
    local http_result http_code response_body message

    API_ERROR_MESSAGE=""
    if [[ -n "$body" ]]; then
        if ! http_result=$(printf '%s' "$body" | curl -sS \
            --connect-timeout 10 \
            --max-time "$APR_API_TIMEOUT" \
            -X "$method" "$url" \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer $OPENAI_API_KEY" \
            --data-binary @- \
            -w '\n%{http_code}' 2>&1); then
            API_ERROR_MESSAGE="$http_result"
            return 1
        fi
    else
        if ! http_result=$(curl -sS \
            --connect-timeout 10 \
            --max-time "$APR_API_TIMEOUT" \
            -X "$method" "$url" \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer $OPENAI_API_KEY" \
            -w '\n%{http_code}' 2>&1); then
            API_ERROR_MESSAGE="$http_result"
            return 1
        fi
    fi

    http_code=$(printf '%s\n' "$http_result" | tail -n 1)
    response_body=$(printf '%s\n' "$http_result" | sed '$d')
    printf '%s' "$response_body" > "$response_file"

    if [[ ! "$http_code" =~ ^2[0-9][0-9]$ ]]; then
        message=$(api_error_from_file "$response_file")
        API_ERROR_MESSAGE="${message:-API request failed with HTTP $http_code}"
        return 1
    fi

    return 0
}

api_build_response_payload() {
    local model="$1"
    local prompt="$2"
    local reasoning_effort="$3"
    local background="$4"
    local slug="$5"
    local max_output_tokens="${6:-$APR_MAX_OUTPUT_TOKENS}"

    jq -nc \
        --arg model "$model" \
        --arg prompt "$prompt" \
        --arg effort "$reasoning_effort" \
        --arg verbosity "${APR_TEXT_VERBOSITY:-}" \
        --arg slug "$slug" \
        --argjson background "$background" \
        --argjson max_output_tokens "$max_output_tokens" \
        '{
            model: $model,
            input: [
                {
                    role: "user",
                    content: [
                        {type: "input_text", text: $prompt}
                    ]
                }
            ],
            background: $background,
            store: true,
            metadata: {apr_slug: $slug}
        }
        | if $effort == "" then . else .reasoning = {effort: $effort} end
        | if $verbosity == "" then . else .text = {verbosity: $verbosity} end
        | if $max_output_tokens > 0 then .max_output_tokens = $max_output_tokens else . end'
}

api_response_status() {
    local response_file="$1"
    jq -r '.status // "unknown"' "$response_file" 2>/dev/null || printf '%s\n' "unknown"
}

api_response_id() {
    local response_file="$1"
    jq -r '.id // empty' "$response_file" 2>/dev/null || true
}

api_response_output_text() {
    local response_file="$1"
    jq -r '[
        (.output_text? // empty),
        (.output[]? | select(.type == "message") | .content[]? | select(.type == "output_text") | .text // empty)
    ] | map(select(. != "")) | join("\n")' "$response_file" 2>/dev/null || true
}

api_write_response_output() {
    local response_file="$1"
    local output_file="$2"
    local output_text

    output_text=$(api_response_output_text "$response_file")
    if [[ -z "$output_text" ]]; then
        API_ERROR_MESSAGE="API response did not contain output_text"
        return 1
    fi

    mkdir -p "$(dirname "$output_file")"
    printf '%s\n' "$output_text" > "$output_file"
}

api_write_session_record() {
    local slug="$1"
    local response_id="$2"
    local status="$3"
    local workflow="$4"
    local round_num="$5"
    local include_impl="$6"
    local model="$7"
    local output_file="$8"
    local log_file="$9"
    local created_at="${10:-}"
    local completed_at="${11:-}"
    local record_path now

    now=$(iso_timestamp)
    [[ -n "$created_at" ]] || created_at="$now"
    record_path=$(api_session_path "$slug")
    mkdir -p "$(api_sessions_dir)"

    jq -nc \
        --arg slug "$slug" \
        --arg response_id "$response_id" \
        --arg status "$status" \
        --arg workflow "$workflow" \
        --argjson round "$round_num" \
        --argjson include_impl "$include_impl" \
        --arg model "$model" \
        --arg output_file "$output_file" \
        --arg log_file "$log_file" \
        --arg created_at "$created_at" \
        --arg updated_at "$now" \
        --arg completed_at "$completed_at" \
        '{
            slug: $slug,
            response_id: $response_id,
            status: $status,
            workflow: $workflow,
            round: $round,
            include_impl: $include_impl,
            model: $model,
            output_file: $output_file,
            log_file: $log_file,
            created_at: $created_at,
            updated_at: $updated_at,
            completed_at: (if $completed_at == "" then null else $completed_at end)
        }' > "$record_path"
}

api_update_session_from_response() {
    local slug="$1"
    local response_file="$2"
    local record_path status completed_at tmp

    record_path=$(api_session_path "$slug")
    [[ -f "$record_path" ]] || return 0
    status=$(api_response_status "$response_file")
    completed_at=""
    case "$status" in
        completed|failed|cancelled|incomplete) completed_at=$(iso_timestamp) ;;
    esac

    tmp="${record_path}.tmp.$$"
    jq \
        --arg status "$status" \
        --arg updated_at "$(iso_timestamp)" \
        --arg completed_at "$completed_at" \
        '.status = $status
         | .updated_at = $updated_at
         | .completed_at = (if $completed_at == "" then .completed_at else $completed_at end)' \
        "$record_path" > "$tmp"
    mv "$tmp" "$record_path"
}

api_create_response_record() {
    local slug="$1"
    local workflow="$2"
    local round_num="$3"
    local include_impl="$4"
    local model="$5"
    local output_file="$6"
    local prompt="$7"
    local reasoning_effort="$8"
    local background="${9:-true}"
    local log_file payload status response_id

    check_api || return 1

    log_file=$(api_response_log_path "$slug")
    mkdir -p "$(dirname "$log_file")"
    payload=$(api_build_response_payload "$model" "$prompt" "$reasoning_effort" "$background" "$slug")

    if ! api_call "POST" "/responses" "$payload" "$log_file"; then
        return 1
    fi

    response_id=$(api_response_id "$log_file")
    status=$(api_response_status "$log_file")
    if [[ -z "$response_id" ]]; then
        API_ERROR_MESSAGE="API response did not include an id"
        return 1
    fi

    API_RESPONSE_ID="$response_id"
    API_RESPONSE_STATUS="$status"
    api_write_session_record "$slug" "$response_id" "$status" "$workflow" "$round_num" "$include_impl" "$model" "$output_file" "$log_file"
}

api_terminal_status() {
    case "$1" in
        completed|failed|cancelled|incomplete) return 0 ;;
        *) return 1 ;;
    esac
}

api_poll_response() {
    local slug="$1"
    local response_id="$2"
    local output_file="$3"
    local log_file="$4"
    local elapsed=0 status message

    while true; do
        if ! api_call "GET" "/responses/$response_id" "" "$log_file"; then
            return 1
        fi

        status=$(api_response_status "$log_file")
        api_update_session_from_response "$slug" "$log_file"
        verbose "api_poll_response: response_id=$response_id status=$status elapsed=${elapsed}s"

        case "$status" in
            completed)
                api_write_response_output "$log_file" "$output_file"
                return $?
                ;;
            failed|cancelled|incomplete)
                message=$(api_error_from_file "$log_file")
                API_ERROR_MESSAGE="${message:-API response ended with status $status}"
                return 1
                ;;
        esac

        if (( elapsed >= APR_API_MAX_POLL_SECONDS )); then
            API_ERROR_MESSAGE="Timed out waiting for API response $response_id"
            return 1
        fi

        sleep "$APR_API_POLL_INTERVAL"
        elapsed=$((elapsed + APR_API_POLL_INTERVAL))
    done
}

api_find_session_record() {
    local session="$1"
    local sessions_dir record

    sessions_dir=$(api_sessions_dir)
    if [[ -f "$sessions_dir/$session.json" ]]; then
        printf '%s\n' "$sessions_dir/$session.json"
        return 0
    fi

    for record in "$sessions_dir"/*.json; do
        [[ -f "$record" ]] || continue
        if jq -e --arg session "$session" '.response_id == $session' "$record" >/dev/null 2>&1; then
            printf '%s\n' "$record"
            return 0
        fi
    done

    return 1
}

api_session_busy_for_round() {
    local workflow="$1"
    local round_num="$2"
    local sessions_dir record

    sessions_dir=$(api_sessions_dir)
    [[ -d "$sessions_dir" ]] || return 1

    for record in "$sessions_dir"/*.json; do
        [[ -f "$record" ]] || continue
        if jq -e \
            --arg workflow "$workflow" \
            --argjson round "$round_num" \
            '(.workflow == $workflow)
             and (.round == $round)
             and ((.status // "") as $status | ["queued", "in_progress", "requires_action"] | index($status) != null)' \
            "$record" >/dev/null 2>&1; then
            return 0
        fi
    done

    return 1
}

# -----------------------------------------------------------------------------
# Pre-flight API Validation
# -----------------------------------------------------------------------------

# Run pre-flight checks before expensive API runs
# Usage: preflight_check readme_path spec_path [impl_path]
# Returns: 0 if all checks pass, 1 if critical failure, 2 if warning only
preflight_check() {
    local readme_path="$1"
    local spec_path="$2"
    local impl_path="${3:-}"
    local has_warnings=false

    verbose "preflight_check: readme=$readme_path spec=$spec_path impl=${impl_path:-<none>}"

    print_info "Running pre-flight checks..."

    # Check direct API readiness. Render and dry-run modes do not call this
    # function, so a real run should fail before spending time assembling output.
    if ! check_api; then
        print_error "Pre-flight failed: $API_ERROR_MESSAGE"
        return 1
    fi
    verbose "preflight: API base URL: ${OPENAI_BASE_URL%/}"
    print_success "Direct API ready (${OPENAI_BASE_URL%/})"

    # Check source files exist and are readable
    if [[ ! -f "$readme_path" ]]; then
        print_error "Pre-flight failed: README not found: $readme_path"
        return 1
    fi
    if [[ ! -r "$readme_path" ]]; then
        print_error "Pre-flight failed: README not readable: $readme_path"
        return 1
    fi
    local readme_size
    readme_size=$(du -h "$readme_path" 2>/dev/null | cut -f1)
    verbose "preflight: README exists: $readme_path ($readme_size)"
    print_success "README: $readme_path ($readme_size)"
    local readme_bytes
    readme_bytes=$(wc -c < "$readme_path" 2>/dev/null || echo "0")
    if [[ "$readme_bytes" -eq 0 ]]; then
        print_error "Pre-flight failed: README is empty: $readme_path"
        return 1
    fi
    if [[ "$readme_bytes" -lt 64 ]]; then
        print_warning "README is suspiciously small (${readme_bytes} bytes): $readme_path"
        has_warnings=true
    fi

    if [[ ! -f "$spec_path" ]]; then
        print_error "Pre-flight failed: Spec not found: $spec_path"
        return 1
    fi
    if [[ ! -r "$spec_path" ]]; then
        print_error "Pre-flight failed: Spec not readable: $spec_path"
        return 1
    fi
    local spec_size
    spec_size=$(du -h "$spec_path" 2>/dev/null | cut -f1)
    verbose "preflight: Spec exists: $spec_path ($spec_size)"
    print_success "Spec: $spec_path ($spec_size)"
    local spec_bytes
    spec_bytes=$(wc -c < "$spec_path" 2>/dev/null || echo "0")
    if [[ "$spec_bytes" -eq 0 ]]; then
        print_error "Pre-flight failed: Spec is empty: $spec_path"
        return 1
    fi
    if [[ "$spec_bytes" -lt 64 ]]; then
        print_warning "Spec is suspiciously small (${spec_bytes} bytes): $spec_path"
        has_warnings=true
    fi

    # Check implementation file if provided
    if [[ -n "$impl_path" ]]; then
        if [[ ! -f "$impl_path" ]]; then
            print_warning "Implementation not found: $impl_path (will be skipped)"
            has_warnings=true
        elif [[ ! -r "$impl_path" ]]; then
            print_warning "Implementation not readable: $impl_path (will be skipped)"
            has_warnings=true
        else
            local impl_size
            impl_size=$(du -h "$impl_path" 2>/dev/null | cut -f1)
            verbose "preflight: Implementation exists: $impl_path ($impl_size)"
            print_success "Implementation: $impl_path ($impl_size)"
            local impl_bytes
            impl_bytes=$(wc -c < "$impl_path" 2>/dev/null || echo "0")
            if [[ "$impl_bytes" -eq 0 ]]; then
                print_error "Pre-flight failed: Implementation is empty: $impl_path"
                return 1
            fi
            if [[ "$impl_bytes" -lt 64 ]]; then
                print_warning "Implementation is suspiciously small (${impl_bytes} bytes): $impl_path"
                has_warnings=true
            fi
        fi
    fi

    echo "" >&2
    if [[ "$has_warnings" == "true" ]]; then
        print_warning "Pre-flight completed with warnings"
        return 2
    else
        print_success "All pre-flight checks passed"
        return 0
    fi
}

# -----------------------------------------------------------------------------
# Prompt Quality Controls
# -----------------------------------------------------------------------------
#
# API review runs are expensive and slow. We fail fast on common
# "how did that even happen?" mistakes and produce actionable errors.

PROMPT_QC_REASON=""
PROMPT_QC_DETAILS=""

# Validate that the prompt we send to the API does not contain obvious
# unexpanded placeholders (e.g. {{README}}). APR does NOT expand mustache-style
# placeholders; if they appear here, the model will see them verbatim.
#
# Usage:
#   prompt_quality_check "$prompt" "$config_path" "label"
#
# Returns:
#   0 if OK
#   1 if fatal (PROMPT_QC_REASON + PROMPT_QC_DETAILS set)
prompt_quality_check() {
    local prompt="$1"
    local config_path="${2:-}"
    local label="${3:-prompt}"

    PROMPT_QC_REASON=""
    PROMPT_QC_DETAILS=""

    # Escape hatch for advanced use (default is strict).
    if [[ "${APR_ALLOW_CURLY_PLACEHOLDERS:-}" == "1" ]]; then
        return 0
    fi

    # Guard: '{{' / '}}' in the prompt almost always means "expected substitution"
    # but nothing will substitute it.
    if printf '%s' "$prompt" | /usr/bin/grep -Fq '{{' || printf '%s' "$prompt" | /usr/bin/grep -Fq '}}'; then
        PROMPT_QC_REASON="Prompt contains unexpanded placeholders ('{{' / '}}'). APR does not substitute these."

        local prompt_hits cfg_hits
        prompt_hits=$(printf '%s\n' "$prompt" | awk -v label="$label" 'index($0,"{{") || index($0,"}}") { printf "  %s:%d: %s\n", label, NR, $0 }' | head -n 8)

        cfg_hits=""
        if [[ -n "$config_path" && -f "$config_path" ]]; then
            cfg_hits=$(awk 'index($0,"{{") || index($0,"}}") { printf "  %s:%d: %s\n", FILENAME, NR, $0 }' "$config_path" | head -n 8)
        fi

        PROMPT_QC_DETAILS=$(
            cat <<EOF
Why this fails:
- The model will literally see "{{README}}" instead of the README contents.
- APR already includes the files in the API prompt bundle; templates should reference them by name.

Fix:
- Remove {{...}} placeholders from your workflow templates.
- Replace with instructions like: "Read the README section" / "Read the spec section".

Offending lines:
${prompt_hits:-  (no prompt hits captured)}

Config hits:
${cfg_hits:-  (no config hits captured)}

Override (not recommended):
- Set APR_ALLOW_CURLY_PLACEHOLDERS=1 to bypass this guard.
EOF
        )

        return 1
    fi

    return 0
}

# -----------------------------------------------------------------------------
# API Job Creation Semantics
# -----------------------------------------------------------------------------
#
# Responses API jobs are stateful once created. APR intentionally does not
# blindly retry POST /responses after transport failures because a retry can
# create duplicate expensive reviews. Polling GET /responses/{id} is safe and
# can be repeated by `apr status` or `apr attach`.

# -----------------------------------------------------------------------------
# Output Validation
# -----------------------------------------------------------------------------
# Validates API output file for completeness.
# Returns 0 if valid, 1 if truncated/incomplete.
# Sets OUTPUT_VALIDATION_REASON with explanation.

OUTPUT_VALIDATION_REASON=""

# Minimum expected size for a revision round output (in bytes)
# Reasoning models typically produce 10KB+ for spec reviews
readonly MIN_OUTPUT_SIZE_BYTES=2048

validate_output_file() {
    local output_file="$1"
    OUTPUT_VALIDATION_REASON=""

    # Check if file exists
    if [[ ! -f "$output_file" ]]; then
        OUTPUT_VALIDATION_REASON="Output file does not exist"
        return 1
    fi

    # Check if file is empty
    local file_size
    file_size=$(wc -c < "$output_file" 2>/dev/null || echo "0")
    if [[ "$file_size" -eq 0 ]]; then
        OUTPUT_VALIDATION_REASON="Output file is empty"
        return 1
    fi

    # Check if file is suspiciously small
    if [[ "$file_size" -lt "$MIN_OUTPUT_SIZE_BYTES" ]]; then
        OUTPUT_VALIDATION_REASON="Output file is suspiciously small (${file_size} bytes, expected >=${MIN_OUTPUT_SIZE_BYTES})"
        return 1
    fi

    # Check if file ends mid-word (truncation indicator)
    # A properly completed response should end with punctuation, newline, or code block
    local last_chars
    last_chars=$(tail -c 50 "$output_file" 2>/dev/null | tr -d '\n\r\t ')
    if [[ -n "$last_chars" ]]; then
        local last_char="${last_chars: -1}"
        # Valid endings: punctuation, quotes, brackets, backticks
        if [[ ! "$last_char" =~ [.!?\)\]\}\"\'\`\>] ]]; then
            # Check if it ends mid-word (letter followed by nothing)
            if [[ "$last_char" =~ [a-zA-Z] ]]; then
                # Read the last 100 chars to see if we're mid-sentence
                local context
                context=$(tail -c 100 "$output_file" 2>/dev/null)
                # If there's no sentence-ending punctuation in the last 100 chars, likely truncated
                if [[ ! "$context" =~ [.!?]$ ]] && [[ ! "$context" =~ \`\`\`$ ]]; then
                    OUTPUT_VALIDATION_REASON="Output appears truncated (ends mid-word: '...${last_chars: -20}')"
                    return 1
                fi
            fi
        fi
    fi

    # Output looks valid
    return 0
}

# -----------------------------------------------------------------------------
# Styled Output Functions
# -----------------------------------------------------------------------------

print_banner() {
    [[ "$QUIET_MODE" == "true" ]] && return

    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum style \
            --border double \
            --border-foreground 212 \
            --padding "0 2" \
            --margin "1 0" \
            --bold \
            --foreground 212 \
            "  Automated Plan Reviser Pro v${VERSION}" \
            "  Iterative AI-Powered Spec Refinement" >&2
    else
        # Get terminal width, default to 60 if unavailable
        local term_width
        term_width=$(tput cols 2>/dev/null || echo "60")
        # Cap at 60 for aesthetics
        (( term_width > 60 )) && term_width=60
        # Minimum width for readability
        (( term_width < 40 )) && term_width=40

        # Generate border of appropriate width
        local border=""
        for ((i=0; i<term_width; i++)); do
            border+="━"
        done

        echo "" >&2
        echo -e "${BOLD}${MAGENTA}${border}${NC}" >&2
        echo -e "  ${BOLD}${WHITE}Automated Plan Reviser Pro${NC} ${DIM}v${VERSION}${NC}" >&2
        echo -e "  ${DIM}Iterative AI-Powered Spec Refinement${NC}" >&2
        echo -e "${BOLD}${MAGENTA}${border}${NC}" >&2
        echo "" >&2
    fi
}

print_header() {
    [[ "$QUIET_MODE" == "true" ]] && return
    local text="$1"
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum style --foreground 214 --bold "$text" >&2
    else
        echo -e "${BOLD}${YELLOW}$text${NC}" >&2
    fi
}

print_success() {
    [[ "$QUIET_MODE" == "true" ]] && return
    local text="$1"
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum style --foreground 82 "✓ $text" >&2
    else
        echo -e "${GREEN}✓${NC} $text" >&2
    fi
}

print_error() {
    local text="$1"
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum style --foreground 196 "✗ $text" >&2
    else
        echo -e "${RED}✗${NC} $text" >&2
    fi
}

print_warning() {
    local text="$1"
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum style --foreground 214 "⚠ $text" >&2
    else
        echo -e "${YELLOW}⚠${NC} $text" >&2
    fi
}

print_info() {
    [[ "$QUIET_MODE" == "true" ]] && return
    local text="$1"
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum style --foreground 39 "ℹ $text" >&2
    else
        echo -e "${CYAN}ℹ${NC} $text" >&2
    fi
}

print_dim() {
    [[ "$QUIET_MODE" == "true" ]] && return
    local text="$1"
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum style --faint "$text" >&2
    else
        echo -e "${DIM}$text${NC}" >&2
    fi
